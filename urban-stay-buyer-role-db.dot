      <TR><TD><FONT COLOR="#e5e7eb">favorites</FONT></TD><TD><FONT COLOR="#e5e7eb">Array(ObjectId)</FONT></TD><TD><FONT COLOR="#e5e7eb">Ref Property</FONT></TD><TD><FONT COLOR="#e5e7eb">Saved property list</FONT></TD></TR>
