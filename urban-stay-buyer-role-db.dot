      <TR><TD><FONT COLOR="#e5e7eb">_id</FONT></TD><TD><FONT COLOR="#e5e7eb">ObjectId</FONT></TD><TD><FONT COLOR="#e5e7eb">Primary Key, Auto Generated</FONT></TD><TD><FONT COLOR="#e5e7eb">Unique ID for each buyer</FONT></TD></TR>
