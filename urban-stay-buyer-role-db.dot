      <TR><TD><FONT COLOR="#e5e7eb">password</FONT></TD><TD><FONT COLOR="#e5e7eb">String</FONT></TD><TD><FONT COLOR="#e5e7eb">Required, Hashed</FONT></TD><TD><FONT COLOR="#e5e7eb">Encrypted password</FONT></TD></TR>
      <TR><TD><FONT COLOR="#e5e7eb">phone</FONT></TD><TD><FONT COLOR="#e5e7eb">String</FONT></TD><TD><FONT COLOR="#e5e7eb">Optional</FONT></TD><TD><FONT COLOR="#e5e7eb">Contact number</FONT></TD></TR>
