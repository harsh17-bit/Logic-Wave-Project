      <TR><TD><FONT COLOR="#e5e7eb">registrationStatus</FONT></TD><TD><FONT COLOR="#e5e7eb">String</FONT></TD><TD><FONT COLOR="#e5e7eb">Enum: incomplete/complete/verified</FONT></TD><TD><FONT COLOR="#e5e7eb">Onboarding progress</FONT></TD></TR>
